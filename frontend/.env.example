# Copy this file to .env.local for local overrides (gitignored by Vite).

# true  -> dashboard generates its own dummy device feed in-browser, no
#          backend needed at all (default; good for demoing this repo alone).
# false -> dashboard fetches from VITE_API_BASE_URL and subscribes to
#          VITE_WS_URL, matching the real backend contract in README.md.
VITE_USE_MOCK=true

# Only used when VITE_USE_MOCK=false
VITE_API_BASE_URL=http://localhost:8080
VITE_WS_URL=ws://localhost:8080/ws
