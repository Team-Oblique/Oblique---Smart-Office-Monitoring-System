# =========================================================================
# Techathon 2026 - Office Device Monitoring System (.env.example)
# Duplicate this file, rename it to '.env', and fill in your private keys.
# =========================================================================

# Your private Discord Bot Token from the Discord Developer Portal
DISCORD_TOKEN=your_discord_bot_token_here

# Your OpenAI API Secret Key for conversational, humanized bot responses
OPENAI_API_KEY=your_openai_api_key_here

# The base URL where Person D's FastAPI backend is hosted
BACKEND_URL=http://127.0.0.1:8000

# The 18-19 digit Discord channel ID where proactive alerts should be posted
ALERT_CHANNEL_ID=your_target_alert_channel_id_here
